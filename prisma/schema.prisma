generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Authenticator2FA {
  id         String    @id @default(uuid())
  enabledAt  DateTime?
  userId     String    @unique
  tempSecret String?
  secret     String?
  backupCode String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthenticatorEmailOTP {
  id        String    @id @default(uuid())
  enabledAt DateTime?
  userId    String    @unique
  expiresAt DateTime
  code      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerification {
  id                          String    @id @default(uuid())
  verifiedAt                  DateTime?
  userId                      String    @unique
  code                        String?
  oldEmail                    String?
  oldEmailBackupCode          String?
  oldEmailBackupCodeExpiresAt DateTime?
  newEmailToVerified          String?
  newEmailToVerifiedCode      String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  user                        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccountRecovery {
  id        String   @id @default(uuid())
  userId    String   @unique
  expiresAt DateTime
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Consent {
  id           String    @id @default(uuid())
  userId       String    @unique
  newsletterAt DateTime?
  opinionAt    DateTime?
  regulationAt DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserPhone {
  id                   String    @id @default(uuid())
  verifiedAt           DateTime?
  userId               String    @unique
  number               BigInt?
  countryCode          Int?
  code                 String?
  numberToConfirm      BigInt?
  countryCodeToConfirm Int?
  codeExpires          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserNotifications {
  id        String    @id @default(uuid())
  enabledAt DateTime?
  userId    String    @unique
  pwa       String?
  native    String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}


model UserIp {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([userId, value])
  @@index([userId])
  @@index([expiresAt])
}

model User {
  id                       String                 @id @default(uuid())
  firstName                String
  lastName                 String?
  email                    String                 @unique
  password                 String
  isPasswordSet            Boolean                @default(true)
  sessionVersion           Int                    @default(1)
  blockedAt                DateTime?
  avatar                   String?
  lang                     Languages              @default(PL)
  role                     Role                   @default(USER)
  companyId                String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  recoveryAccount          AccountRecovery?
  authenticator2FA         Authenticator2FA?
  authenticatorEmailOTP    AuthenticatorEmailOTP?
  bugs                     Bug[]
  workerSettings           CompanyWorkerSettings?
  consent                  Consent?
  emailVerification        EmailVerification?
  listings                 Listing[]
  company                  Company?               @relation("WorkerCompany", fields: [companyId], references: [id], onDelete: NoAction)
  notifications            UserNotifications?
  phone                    UserPhone?
  reportsAsTarget          Report[]               @relation("ReportTargetUser")
  reportsAsReporter        Report[]               @relation("ReportReporter")
  loginIps                 UserIp[]
  listingInteractions      ListingInteraction[]   @relation("ListingInteractionUser")
  ownedListingInteractions ListingInteraction[]   @relation("ListingInteractionOwner")

  @@index([email])
  @@index([id, role, blockedAt, companyId])
  @@index([companyId, blockedAt])
}

model CompanyWorkerSettings {
  id          String                    @id @default(uuid())
  userId      String                    @unique
  companyId   String
  permissions CompanyWorkerPermission[]
  company     Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

model CompanyRegistry {
  id        String     @id @default(uuid())
  number    String
  country   TaxCountry @default(PL)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([number, country])
}

model CompanyPhone {
  id                   String    @id @default(uuid())
  verifiedAt           DateTime?
  companyId            String    @unique
  number               BigInt?
  countryCode          Int?
  code                 String?
  numberToConfirm      BigInt?
  countryCodeToConfirm Int?
  codeExpires          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model CompanySettings {
  id                               String    @id @default(uuid())
  companyId                        String    @unique
  loginPasswordAt                  DateTime?
  twoFactorAuthenticationEnabledAt DateTime?
  company                          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Company {
  id                      String                  @id @default(uuid())
  idnumber                Int                     @unique @default(autoincrement())
  slug                    String?
  name                    String                  @unique
  urlInstagram            String?
  urlFacebook             String?
  urlTiktok               String?
  blockedAt               DateTime?
  avatar                  String?
  bannerHero              String?
  description             String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  bugs                    Bug[]
  phone                   CompanyPhone?
  settings                CompanySettings?
  workersSettings         CompanyWorkerSettings[]
  listings                Listing[]
  workers                 User[]                  @relation("WorkerCompany")
  reportsAsTarget         Report[]                @relation("ReportTargetCompany")
  listingInteractions     ListingInteraction[]

  @@index([id, slug])
  @@index([slug])
}

model Geolocation {
  id      String @id @default(uuid())
  address String @unique
  lat     Float
  lng     Float

  @@index([lat, lng])
}

model Bug {
  id                 String         @id @default(uuid())
  userId             String
  companyId          String?
  images             String[]
  video              String?
  status             BugStatus
  description        String
  timestamp          DateTime
  environment        BugEnvironment
  actionsBeforeError String
  errorMessage       String?
  expectedBehavior   String?
  isReproducible     Boolean
  priority           BugPriority?
  answer             String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  company            Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
}

model ListingLocation {
  id            String    @id @default(uuid())
  listingId     String    @unique
  country       Country   @default(POLAND)
  postalCode    String
  cityCustom    String?
  streetName    String
  streetNumber  String
  flatNumber    String?
  lat           Float
  lng           Float
  cityId        String?
  city          City?     @relation("ListingLocationCity", fields: [cityId], references: [id], onDelete: SetNull)
  districtId    String?
  district      District? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  listing       Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  nearestCityId String?
  nearestCity   City?     @relation("ListingLocationNearestCity", fields: [nearestCityId], references: [id], onDelete: SetNull)

  @@index([lat, lng])
  @@index([cityId])
  @@index([districtId])
  @@index([cityId, districtId])
}

model ListingPayment {
  id                 String               @id @default(uuid())
  listingId          String
  status             ListingPaymentStatus
  free               Boolean
  monthsToAdd        Int?
  expiresAtBeforeAdd DateTime?
  expiresAtAfterAdd  DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  listing            Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([listingId, status])
  @@index([status, createdAt])
  @@index([listingId, status, createdAt])
}

model ListingInteraction {
  id   String                 @id @default(uuid())
  type ListingInteractionType

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation("ListingInteractionUser", fields: [userId], references: [id], onDelete: SetNull)

  ownerUserId String?
  ownerUser   User?   @relation("ListingInteractionOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  ownerCompanyId String?
  ownerCompany   Company? @relation(fields: [ownerCompanyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([listingId, ownerCompanyId])
  @@index([ownerCompanyId, type, createdAt])
  @@index([ownerUserId, type, createdAt])
  @@index([userId, type, createdAt])
  @@index([type, createdAt])
}

model ListingImage {
  id String @id @default(uuid())

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  isDefault Boolean

  @@index([listingId, isDefault])
}

model Listing {
  id            String               @id @default(uuid())
  listingIndex  Int                  @unique @default(autoincrement())
  slug          String               @unique
  userId        String?
  companyId     String?
  status        ListingStatus
  deleteReason  ListingDeleteReason?
  category      ListingCategory
  workMode      WorkMode
  title         String
  description   String?
  salaryFrom    Int?
  salaryTo      Int?
  showPhone     Boolean              @default(true)
  showEmail     Boolean              @default(false)
  interactions  ListingInteraction[]
  expiresAt     DateTime?
  availableFrom DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  company       Company?             @relation(fields: [companyId], references: [id], onDelete: NoAction)
  user          User?                @relation(fields: [userId], references: [id], onDelete: NoAction)
  location      ListingLocation?
  payments      ListingPayment[]
  reports       Report[]             @relation("ReportListing")
  images        ListingImage[]

  @@index([status, category, createdAt])
  @@index([status, category, expiresAt])
  @@index([status, category, workMode, createdAt])
  @@index([userId, status, expiresAt])
  @@index([companyId, status, expiresAt])
  @@index([companyId, createdAt])
  @@index([userId, createdAt])
}

model Report {
  id                  String     @id @default(uuid())
  type                ReportType
  listingId           String?
  listing             Listing?   @relation("ReportListing", fields: [listingId], references: [id], onDelete: SetNull)
  targetUserId        String?
  targetUser          User?      @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCompanyId     String?
  targetCompany       Company?   @relation("ReportTargetCompany", fields: [targetCompanyId], references: [id], onDelete: SetNull)
  targetUserEmailHash String?
  userId              String?
  user                User?      @relation("ReportReporter", fields: [userId], references: [id], onDelete: SetNull)
  description         String?
  createdAt           DateTime   @default(now())

  @@index([listingId])
  @@index([targetUserId])
  @@index([targetCompanyId])
  @@index([userId])
}

model City {
  id          String @id @default(cuid())
  name        String
  nameSearch  String @unique
  voivodeship String // eq. "mazowieckie"

  lat Float
  lng Float

  radiusKm Float

  districts               District[]
  listingLocations        ListingLocation[] @relation("ListingLocationCity")
  nearestListingLocations ListingLocation[] @relation("ListingLocationNearestCity")

  @@unique([name, voivodeship, nameSearch])
  @@index([voivodeship])
  @@index([nameSearch])
  @@index([name])
  @@index([lat, lng])
  @@index([lat])
  @@index([lng])
}

model District {
  id         String @id @default(cuid())
  name       String
  nameSearch String
  cityId     String
  city       City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  lat              Float
  lng              Float
  listingLocations ListingLocation[]

  @@unique([name, cityId])
  @@unique([id, cityId])
  @@index([nameSearch])
  @@index([cityId])
}

enum ListingInteractionType {
  CONTACT
  VIEW
}

enum ReportType {
  ILLEGAL_CONTENT
  SCAM_FRAUD
  MISLEADING_INFO
  SPAM
  OFFENSIVE_CONTENT
  WRONG_CATEGORY
  OTHER
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum ListingPaymentStatus {
  PAID
  REJECTED
  EXPIRED
  UNPAID
  FREE
  PENDING
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  REJECTED
  EXPIRED
  DELETED
  UNPAID
}

enum ListingDeleteReason {
  POSITION_FILLED
  NO_LONGER_AVAILABLE
  CHANGED_MIND
  DUPLICATE
  OTHER
}

enum ListingCategory {
  IT
  SALES
  MARKETING
  FINANCE
  HR
  ADMINISTRATION
  CUSTOMER_SERVICE
  LOGISTICS
  PRODUCTION
  CONSTRUCTION
  GASTRONOMY
  HEALTHCARE
  EDUCATION
  ENGINEERING
  LAW
  OTHER
}

enum Role {
  B2B_WORKER
  B2B_OWNER
  USER
  ADMIN
  ADMIN_SUPER
}

enum CompanyWorkerPermission {
  MANAGE_WORKERS
  MANAGE_LISTINGS
}

enum Languages {
  PL
  EN
}

enum Country {
  POLAND
}

enum TaxCountry {
  PL
}

enum BugPriority {
  SMALL
  MEDIUM
  BIG
}

enum BugEnvironment {
  DESKTOP_CHROME
  DESKTOP_FIREFOX
  DESKTOP_EDGE
  DESKTOP_OTHER
  PHONE_ANDROID
  PHONE_IOS
  PHONE_OTHER
}

enum BugStatus {
  REPORTED
  IN_PROGRESS
  RESOLVED
  REJECTED
  DUPLICATE
}
