  "private": true,
  "scripts": {
    "build": "prisma generate && npm run images:gen && react-router build",
    "build-emails": "npm install --frozen-lockfile && email build",
    "build-vercel": "npm run check-types && npm run lint:fix && npm run check-lint && npm run check-cspell && npm run build",
    "check-cspell": "cspell --no-progress .",
    "check-format": "npm run prettier --list-different",
    "check-lint": "npm run lint",
    "check-lint-staged": "npx lint-staged",
    "check-types": "npm run generate-locales-types && react-router typegen && tsc --noEmit",
    "cspell": "cspell .",
    "dev": "cross-env NODE_OPTIONS=--import=./instrument.server.mjs npm run images:gen && npm-run-all --parallel dev:locales dev:server",
    "dev-emails": "email dev",
    "dev:locales": "chokidar \"./app/locales/pl/*.json\" -c \"npm run generate-locales-types\"",
    "dev:server": "react-router dev",
    "export-emails": "email export",
    "generate-locales-types": "i18next-resources-for-ts interface -i ./app/locales/pl -o ./@types/i18next-resources.d.ts",
    "generate-static": "node generate-static.js",
    "get-env": "vercel env pull .env.local",
    "images:gen": "ts-node scripts/generate-images.ts && npm run lint-json:fix",
    "lint": "eslint --no-cache",
    "lint-json:fix": "eslint \"**/*.json\" --fix",
    "lint:fix": "eslint --no-cache --fix",
    "postinstall": "prisma generate",
    "preinstall": "npx only-allow npm",
    "prepare": "node ./.husky/install.mjs",
    "prettier": "npx prettier --check .",
    "prettier:fix": "npx prettier --write .",
    "prisma-generate": "npx prisma generate",
    "prisma-migrate": "np!x prisma migrate dev --name name_of_migration",
    "prisma-seed": "npx prisma db seed",
    "prisma-studio": "npx prisma studio",
    "prisma-update-db-prd": "npx prisma migrate deploy",
    "sort-locales": "node scripts/sort-json.js",
    "start": "cross-env NODE_OPTIONS=--import=./instrument.server.mjs react-router-serve ./build/server/index.js",
    "start-e2e": "react-router-serve ./build/server/index.js",
    "start-emails": "email preview ./emails",
    "test:e2e": "cross-env VITE_IS_E2E=true playwright test",
    "test:e2e:debug": "cross-env VITE_IS_E2E=true playwright test --debug",
    "test:e2e:headed": "cross-env VITE_IS_E2E=true playwright test --headed",
    "test:e2e:ui": "cross-env VITE_IS_E2E=true playwright test --ui",
    "test:new": "cross-env VITE_IS_E2E=true npm-run-all --parallel dev:server test:record",
    "test:record": "cross-env VITE_IS_E2E=true npx playwright codegen http://localhost:5173",
    "validate": "npm-run-all --parallel check-types check-format lint build"
  },
  "sideEffects": false,
  "type": "module"
}
